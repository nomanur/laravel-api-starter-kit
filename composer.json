{
    "name": "nomanurrahman/api-starter-kit",
    "description": "A complete Laravel API boilerplate with authentication, transformers, exception handling, and scaffolding commands",
    "keywords": [
        "nomanurrahman",
        "api",
        "laravel",
        "boilerplate",
        "rest-api",
        "starter-kit",
        "fractal",
        "sanctum"
    ],
    "homepage": "https://github.com/nomanurrahman/api-starter-kit",
    "license": "MIT",
    "type": "library",
    "authors": [
        {
            "name": "nomanur rahman",
            "email": "nomanurrahman@gmail.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2|^8.3|^8.4",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/http": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/database": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/auth": "^10.0|^11.0|^12.0|^13.0",
        "spatie/fractalistic": "^2.0",
        "laravel/sanctum": "^3.0|^4.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0|^10.0|^11.0",
        "phpunit/phpunit": "^10.0|^11.0|^12.0",
        "pestphp/pest": "^2.0|^3.0|^4.0"
    },
    "autoload": {
        "psr-4": {
            "LaravelApi\\StarterKit\\": "src/"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "LaravelApi\\StarterKit\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "test-coverage": "vendor/bin/phpunit --coverage-html coverage"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "LaravelApi\\StarterKit\\ApiStarterKitServiceProvider"
            ],
            "aliases": {
                "ApiBoilerplate": "LaravelApi\\StarterKit\\ApiBoilerplateFacade"
            }
        }
    }
}
